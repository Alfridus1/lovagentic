{
  "name": "lovagentic",
  "version": "0.1.2",
  "description": "Agentic CLI for Lovable.dev — agents in, apps out. Send prompts, verify builds, fix errors, and publish from the terminal.",
  "type": "module",
  "license": "MIT",
  "author": "Tobias Kub <tobias@coppen.energy>",
  "homepage": "https://lovagentic.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alfridus1/lovagentic.git"
  },
  "bugs": {
    "url": "https://github.com/Alfridus1/lovagentic/issues"
  },
  "keywords": [
    "lovable",
    "lovable.dev",
    "cli",
    "agent",
    "agentic",
    "playwright",
    "automation",
    "codegen",
    "ai-agents"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "lovagentic": "./src/cli.js"
  },
  "files": [
    "src",
    "skills",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node ./src/cli.js",
    "help": "node ./src/cli.js --help",
    "doctor": "node ./src/cli.js doctor",
    "generate:commands": "node ./scripts/generate-command-reference.mjs",
    "check:commands": "node ./scripts/generate-command-reference.mjs --check",
    "test": "node --test ./test/browser.attachments.test.js ./test/browser.idle.test.js ./test/browser.multiline.test.js ./test/orchestration.test.js ./test/profile.test.js",
    "check:syntax": "node --check ./src/browser.js && node --check ./src/cli.js && node --check ./src/config.js && node --check ./src/orchestration.js && node --check ./src/profile.js && node --check ./src/url.js",
    "check": "npm run check:syntax && npm test && npm run check:commands",
    "ci": "npm run check"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "playwright": "^1.54.0"
  }
}
